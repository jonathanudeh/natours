    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.3.1",
    "express": "^4.22.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.4.0",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "html-to-text": "^10.0.0",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^5.13.23",
    "morgan": "^1.10.1",
    "multer": "^1.4.4",
    "nodemailer": "^8.0.5",
    "pug": "^3.0.4",
    "sharp": "^0.34.5",
